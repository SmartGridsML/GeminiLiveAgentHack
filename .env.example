GOOGLE_API_KEY=your_gemini_api_key_here
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
FIRESTORE_COLLECTION=pitchmirror_sessions
ENVIRONMENT=development
# Set to "vertex" to use Vertex AI instead of Gemini Developer API
GEMINI_BACKEND=gemini
# Shared token for REST + WebSocket auth (Bearer or x-api-key).
# Leave empty only for local development.
API_BEARER_TOKEN=

# Comma-separated origins. Use "*" only for local/dev.
# Example: http://localhost:8080,https://pitchmirror.example.com
CORS_ALLOWED_ORIGINS=*

# Standard request/session guards (tune for your traffic profile)
HTTP_MAX_REQUESTS_PER_MINUTE=120
WS_MAX_CONNECTIONS_PER_MINUTE=20
WS_MAX_CONCURRENT_PER_IP=2
WS_MAX_MESSAGES_PER_SECOND=30
WS_MAX_BYTES_PER_SECOND=1000000
WS_MAX_BINARY_FRAME_BYTES=600000
WS_MAX_TEXT_FRAME_BYTES=4096
RECENT_SESSION_CACHE_SIZE=200
SLIDE_MAX_UPLOAD_BYTES=20971520
SLIDE_MAX_PAGES=20
SLIDE_MAX_WIDTH=1024
SLIDE_STORE_MAX_USERS=64
SLIDE_STORE_TTL_S=21600

# Feature flags
ENABLE_SCREEN_SHARE=true
ENABLE_IMAGE_GENERATION=true
DEMO_MODE_DEFAULT=false

# Low-cost multimodal generation controls
PITCHMIRROR_IMAGE_MODEL=imagen-4.0-fast-generate-001
IMAGE_GENERATION_TIMEOUT_S=24
IMAGE_GENERATION_RETRIES=1

# Override when stable model aliases ship (remove _preview suffix)
# PITCHMIRROR_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
# PITCHMIRROR_ANALYSIS_MODEL=gemini-2.5-flash
